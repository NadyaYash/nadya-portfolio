---
import App, { getPageSeo } from "../App.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";

const path = "/impressum";
const seo = getPageSeo(path);
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={path} image={seo.image} jsonLd={seo.jsonLd}>
  <App initialPath={path} client:load />
</BaseLayout>
