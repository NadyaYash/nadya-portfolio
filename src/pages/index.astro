---
import App, { getPageSeo } from "../App.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";

const seo = getPageSeo("/");
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath="/" image={seo.image} jsonLd={seo.jsonLd}>
  <App initialPath="/" client:load />
</BaseLayout>
