---
import App, { getPageSeo, getProjectPath, getProjectSlug, projects } from "../../../App.jsx";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withLocalePath } from "../../../i18n.js";

export function getStaticPaths() {
  return projects.map((item) => {
    const path = withLocalePath(getProjectPath(item), "de");
    return {
      params: { slug: getProjectSlug(item) },
      props: { path },
    };
  });
}

const { path } = Astro.props;
const seo = getPageSeo(path);
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={path} image={seo.image} jsonLd={seo.jsonLd} lang="de">
  <App initialPath={path} client:load />
</BaseLayout>
